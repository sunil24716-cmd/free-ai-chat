# ═══════════════════════════════════════════════════════
#  Free AI Chat — Environment Variables
#  Copy to .env and fill in the providers you want
#  You only need ONE provider key to get started!
# ═══════════════════════════════════════════════════════

# ── SERVER ──────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── PROVIDER 1: GROQ (Recommended — fastest + generous free tier) ──────────
# Sign up free: https://console.groq.com
# Free tier: 14,400 requests/day, 6,000 tokens/min
# Best models: llama-3.3-70b-versatile, deepseek-r1-distill-llama-70b
GROQ_API_KEY=gsk_your_key_here

# ── PROVIDER 2: GOOGLE GEMINI ──────────────────────────────────────────────
# Sign up free: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, 1M tokens/day (Flash), 2M context window
# Best models: gemini-2.0-flash, gemini-1.5-pro
GEMINI_API_KEY=AIza_your_key_here

# ── PROVIDER 3: OPENROUTER ─────────────────────────────────────────────────
# Sign up free: https://openrouter.ai/keys
# Permanently free models: llama-3.3-70b:free, mistral-7b:free, deepseek-r1:free
OPENROUTER_API_KEY=sk-or-your_key_here

# ── PROVIDER 4: OLLAMA (fully local — no key needed) ──────────────────────
# Install: https://ollama.com/download
# Then: ollama pull llama3.2  (or any model)
# Then: ollama serve           (starts on localhost:11434)
# OLLAMA_URL=http://localhost:11434   # default — change if remote

# ── PROVIDER 5: HUGGING FACE ───────────────────────────────────────────────
# Sign up free: https://huggingface.co/settings/tokens
# Create a token with "Read" scope
# Free tier: rate-limited but no hard daily cap
HF_API_KEY=hf_your_key_here

# ── OPTIONAL ────────────────────────────────────────────
# ALLOWED_ORIGIN=https://yourdomain.com
